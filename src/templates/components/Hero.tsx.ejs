import type { ReactNode } from 'react';

interface HeroProps {
  title?: string;
  subtitle?: string;
  className?: string;
  children?: ReactNode;
  [key: string]: any;
}

export default function Hero({ title, subtitle, className = '', children, ...rest }: HeroProps) {
  return (
    <section className={className} {...rest}>
      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
        {title && <h1 className="text-5xl font-bold tracking-tight">{title}</h1>}
        {subtitle && <p className="mt-6 text-xl opacity-90">{subtitle}</p>}
        {children && <div className="mt-10 flex items-center justify-center gap-4">{children}</div>}
      </div>
    </section>
  );
}
