import type { ReactNode } from 'react';

interface CardProps {
  title?: string;
  description?: string;
  image?: string;
  className?: string;
  children?: ReactNode;
  [key: string]: any;
}

export default function Card({ title, description, image, className = '', children, ...rest }: CardProps) {
  return (
    <div className={`rounded-lg overflow-hidden ${className}`} {...rest}>
      {image && <img src={image} alt={title || ''} className="w-full h-48 object-cover" />}
      <div className="p-6">
        {title && <h3 className="text-xl font-semibold mb-2">{title}</h3>}
        {description && <p className="opacity-80">{description}</p>}
        {children}
      </div>
    </div>
  );
}
