import type { ReactNode } from 'react';

interface TextProps {
  tag?: string;
  content?: string;
  className?: string;
  children?: ReactNode;
  [key: string]: any;
}

export default function Text({ tag = 'p', content, className = '', children, ...rest }: TextProps) {
  const Tag = tag as keyof JSX.IntrinsicElements;
  return (
    <Tag className={className} {...rest}>
      {content || children}
    </Tag>
  );
}
